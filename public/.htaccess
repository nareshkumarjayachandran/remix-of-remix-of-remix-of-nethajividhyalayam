# Cache static assets for 1 year (hashed filenames from Vite)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # Hashed assets (Vite build output) - immutable cache
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images and fonts - long cache
  <FilesMatch "\.(jpg|jpeg|png|webp|svg|ico|woff|woff2|mp4)$">
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>

  # HTML - no cache (always fetch fresh for SPA routing)
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Service worker registration - short cache
  <FilesMatch "registerSW\.js$">
    Header set Cache-Control "no-cache, max-age=0"
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the requested file or directory exists, serve it directly
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Otherwise, redirect all requests to index.html for SPA routing
  RewriteRule ^ index.html [QSA,L]
</IfModule>
